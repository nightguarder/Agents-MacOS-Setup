(version 1)

;; DEFAULT ALLOW, THEN DENY
(allow default)

;; --- 1. DENY HOME DIRECTORY (global block) ---
;; Block ALL read/write to admin's home by default
(deny file-write*)
(deny file-read* (subpath "/Users/cyrils"))

;; --- 2. DENY PROCESS EXEC (global block) ---
(deny process-exec)

;; --- 3. ALLOW SYSTEM BINARIES ---
(allow process-exec (subpath "/bin"))
(allow process-exec (subpath "/usr/bin"))
(allow process-exec (subpath "/sbin"))
(allow process-exec (subpath "/usr/sbin"))

;; --- 4. ALLOW TOOLCHAIN ---
(allow process-exec (subpath "/opt/homebrew"))

;; --- 5. BLOCK HIGH-RISK LAUNCHERS ---
(deny process-exec (literal "/bin/launchctl"))
(deny process-exec (literal "/usr/bin/open"))
(deny process-exec (literal "/usr/bin/osascript"))
(deny process-exec (literal "/usr/bin/sudo"))

;; --- 6. WORKSPACE: PROJECT DIRECTORY ONLY ---
;; Only allow read/write to Developer folder (your project work)
(allow file-read* (subpath "/Users/cyrils/Developer"))
(allow file-write* (subpath "/Users/cyrils/Developer"))
(allow file-read* (subpath (param "PROJECT_DIR")))
(allow file-write* (subpath (param "PROJECT_DIR")))

;; --- 7. AGENT HOME (full control) ---
(allow file-read* (subpath "/Users/agents"))
(allow file-write* (subpath "/Users/agents"))

;; --- 8. TEMP DIRS ---
(allow file-read* file-write* (subpath "/private/tmp"))
(allow file-read* file-write* (subpath "/private/var/folders"))

;; --- 9. OPENCODE STATE ---
(allow file-read* (subpath "/Users/cyrils/.config/opencode"))
(allow file-write* (subpath "/Users/cyrils/.config/opencode"))
(allow file-read* (subpath "/Users/cyrils/.local/share/opencode"))
(allow file-write* (subpath "/Users/cyrils/.local/share/opencode"))
(allow file-read* (subpath "/Users/cyrils/.cache/opencode"))
(allow file-write* (subpath "/Users/cyrils/.cache/opencode"))

;; --- 10. METADATA (for path traversal) ---
(allow file-read-metadata (literal "/"))
(allow file-read-metadata (subpath "/Users"))
(allow file-read-metadata (subpath "/Users/cyrils"))
(allow file-read-metadata (subpath "/Users/cyrils/Developer"))

;; --- 11. NETWORK ---
(allow network-outbound)
(allow network-bind)